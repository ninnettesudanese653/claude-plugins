{
  "name": "socials",
  "version": "1.0.2",
  "description": "Claude Code plugin: MCP server that connects Claude to the Socials browser extension (X, LinkedIn, Reddit) via a local WebSocket bridge (paid plans).",
  "author": {
    "name": "Brainrot Creations"
  },
  "homepage": "https://socials.brainrotcreations.com",
  "repository": "https://github.com/Brainrot-Creations/claude-plugins",
  "license": "MIT",
  "keywords": [
    "mcp",
    "socials",
    "browser-extension",
    "x",
    "linkedin",
    "reddit",
    "claude-code-plugin"
  ],
  "mcpServers": {
    "socials": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.cjs"],
      "env": {
        "SOCIALS_MCP_RECLAIM_PORT": "1"
      }
    }
  }
}
