{
  "name": "socials-claude-code-plugin",
  "version": "1.0.8",
  "description": "Official Socials Claude Code plugin: MCP server for the Socials browser extension (Claude Desktop compatible)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "socials-claude-code-plugin": "./dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-code-plugin",
    "socials",
    "browser-extension",
    "x",
    "linkedin",
    "reddit",
    "socials-claude-code-plugin"
  ],
  "homepage": "https://socials.brainrotcreations.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brainrot-Creations/claude-plugins.git"
  },
  "bugs": {
    "url": "https://github.com/Brainrot-Creations/claude-plugins/issues"
  },
  "license": "MIT",
  "files": [
    ".claude-plugin",
    ".mcp.json",
    "agents",
    "commands",
    "dist",
    "scripts",
    "skills",
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "claude_desktop_config.example.json"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.cjs",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
